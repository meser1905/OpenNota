// OpenNota database schema.
//
// Datasource: SQLite — a single file on disk, no server to install. See
// docs/adr/0001-sqlite-for-mvp.md for the trade-offs this implies:
//   * No native enum type: role/type/scale columns are plain `String` values,
//     validated against the enums in @opennota/shared.
//   * No native decimal type: grade and weight values are stored as `Float`
//     and rounded to two decimals in the service layer.
//
// All ids are cuids. Tables carry `createdAt`/`updatedAt`; entities that can be
// archived also carry a nullable `deletedAt` for soft deletion.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// An application user. `role` holds a UserRole value (ADMIN, PRINCIPAL,
/// TEACHER, STUDENT, GUARDIAN). Role-specific data lives in the profile tables.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  teacherProfile  TeacherProfile?
  studentProfile  StudentProfile?
  guardianProfile GuardianProfile?
  refreshTokens   RefreshToken[]
  gradesGiven     Grade[]          @relation("GradedBy")

  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

/// Hashed, revocable refresh token. Enables `POST /auth/refresh` rotation and
/// `POST /auth/logout` revocation without trusting a stateless token alone.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// A school. The MVP runs a single institution; the schema already keys
/// academic years to it so multi-institution support is an additive change.
model Institution {
  id        String    @id @default(cuid())
  name      String
  taxId     String?
  address   String?
  phone     String?
  email     String?
  logoPath  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  academicYears AcademicYear[]

  @@map("institutions")
}

/// A school year. Only one per institution should be `isActive`; the service
/// layer enforces that invariant.
model AcademicYear {
  id            String   @id @default(cuid())
  institutionId String
  year          Int
  startDate     DateTime
  endDate       DateTime
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution  @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  terms       Term[]
  classGroups ClassGroup[]
  enrollments Enrollment[]

  @@unique([institutionId, year])
  @@index([institutionId])
  @@map("academic_years")
}

/// A grading period within a year. `type` holds a TermType value. A closed
/// term (`isClosed`) no longer accepts grade edits.
model Term {
  id             String   @id @default(cuid())
  academicYearId String
  name           String
  type           String
  number         Int
  startDate      DateTime
  endDate        DateTime
  isClosed       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  academicYear         AcademicYear          @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  evaluations          Evaluation[]
  gradingWeightConfigs GradingWeightConfig[]
  termAverages         TermAverage[]

  @@unique([academicYearId, number])
  @@index([academicYearId])
  @@map("terms")
}

/// A class/section. `level` holds an EducationLevel value.
model ClassGroup {
  id             String    @id @default(cuid())
  academicYearId String
  name           String
  level          String
  year           Int
  section        String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  subjects     Subject[]
  enrollments  Enrollment[]

  @@index([academicYearId])
  @@map("class_groups")
}

/// A subject taught to a class group.
model Subject {
  id           String    @id @default(cuid())
  classGroupId String
  name         String
  description  String?
  color        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  classGroup           ClassGroup            @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  teacherSubjects      TeacherSubject[]
  evaluations          Evaluation[]
  gradingWeightConfigs GradingWeightConfig[]
  termAverages         TermAverage[]

  @@index([classGroupId])
  @@map("subjects")
}

/// Teacher-specific data for a User with the TEACHER role.
model TeacherProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherSubjects TeacherSubject[]
  evaluations     Evaluation[]

  @@map("teacher_profiles")
}

/// Assignment of a teacher to a subject. `isLead` marks the lead teacher.
model TeacherSubject {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  isLead    Boolean  @default(false)
  createdAt DateTime @default(now())

  teacher TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
  @@index([subjectId])
  @@map("teacher_subjects")
}

/// Student-specific data for a User with the STUDENT role.
model StudentProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  nationalId    String   @unique
  birthDate     DateTime
  studentNumber String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments      Enrollment[]
  grades           Grade[]
  termAverages     TermAverage[]
  studentGuardians StudentGuardian[]

  @@map("student_profiles")
}

/// A student's membership in a class group for an academic year.
model Enrollment {
  id             String   @id @default(cuid())
  studentId      String
  classGroupId   String
  academicYearId String
  enrolledAt     DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  student      StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classGroup   ClassGroup     @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, classGroupId, academicYearId])
  @@index([classGroupId])
  @@index([academicYearId])
  @@map("enrollments")
}

/// Guardian-specific data for a User with the GUARDIAN role.
model GuardianProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  nationalId   String?
  relationship String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentGuardians StudentGuardian[]

  @@map("guardian_profiles")
}

/// Links a guardian to a student. `isPrimary` marks the main contact.
model StudentGuardian {
  id         String   @id @default(cuid())
  guardianId String
  studentId  String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  guardian GuardianProfile @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student  StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([guardianId, studentId])
  @@index([studentId])
  @@map("student_guardians")
}

/// Per-subject, per-term weighting of evaluation types. The five weights are
/// validated to sum to 100 by the service layer.
model GradingWeightConfig {
  id                String   @id @default(cuid())
  subjectId         String
  termId            String
  examWeight        Float    @default(0)
  assignmentWeight  Float    @default(0)
  performanceWeight Float    @default(0)
  oralWeight        Float    @default(0)
  projectWeight     Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term    Term    @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([subjectId, termId])
  @@map("grading_weight_configs")
}

/// A graded activity. `type` holds an EvaluationType value and `scale` a
/// GradeScale value. Grades can be edited while `isPublished` and the term is
/// open.
model Evaluation {
  id           String    @id @default(cuid())
  subjectId    String
  termId       String
  teacherId    String
  title        String
  description  String?
  type         String
  date         DateTime
  weight       Float     @default(1)
  scale        String
  maxScore     Float     @default(10)
  minScore     Float     @default(1)
  passingScore Float     @default(6)
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  subject Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term    Term           @relation(fields: [termId], references: [id], onDelete: Cascade)
  teacher TeacherProfile @relation(fields: [teacherId], references: [id])
  grades  Grade[]

  @@index([subjectId])
  @@index([termId])
  @@index([teacherId])
  @@map("evaluations")
}

/// One student's result for one evaluation. Either `numericValue` or
/// `conceptualValue` is set depending on the evaluation's scale; `wasAbsent`
/// marks a non-attendance with no score.
model Grade {
  id              String   @id @default(cuid())
  evaluationId    String
  studentId       String
  numericValue    Float?
  conceptualValue String?
  comments        String?
  wasAbsent       Boolean  @default(false)
  gradedById      String
  gradedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  evaluation Evaluation     @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  student    StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gradedBy   User           @relation("GradedBy", fields: [gradedById], references: [id])

  @@unique([evaluationId, studentId])
  @@index([studentId])
  @@map("grades")
}

/// Materialized term average for a student in a subject. Recomputed by the
/// GradeCalculationService whenever an underlying grade changes.
model TermAverage {
  id                String   @id @default(cuid())
  studentId         String
  subjectId         String
  termId            String
  average           Float
  conceptualAverage String?
  passed            Boolean  @default(false)
  lastCalculatedAt  DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term    Term           @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, termId])
  @@index([termId])
  @@map("term_averages")
}
