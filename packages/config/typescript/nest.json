{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "OpenNota NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "declaration": true,
    "sourceMap": true,
    "incremental": true,
    "outDir": "dist",
    "baseUrl": "."
  }
}
