# === Database (SQLite file, no server) ===
# The path is relative to packages/db/prisma/schema.prisma, so "../data"
# resolves the database file to packages/db/data/opennota.db.
DATABASE_URL="file:../data/opennota.db"

# === Backend (NestJS) ===
API_PORT=3001
NODE_ENV=development
JWT_SECRET=dev-only-change-me-please-this-is-not-a-real-secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=dev-only-change-me-please-this-is-not-a-real-secret-either
REFRESH_TOKEN_EXPIRES_IN=7d
LOG_LEVEL=debug

# === Frontend (Next.js) ===
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-only-change-me-please

# === Email (local file transport, .eml files) ===
EMAIL_OUTPUT_DIR=./emails
EMAIL_FROM=no-reply@opennota.local

# === Local filesystem dirs ===
UPLOAD_DIR=./uploads
PDF_OUTPUT_DIR=./generated
